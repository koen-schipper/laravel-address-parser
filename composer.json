{
    "name": "koenschipper/laravel-address-parser",
    "description": "Laravel address parser to parse dutch addresses.",
    "keywords": [
        "koenschipper",
        "laravel",
        "address-parser"
    ],
    "homepage": "https://github.com/koenschipper/laravel-address-parser",
    "license": "MIT",
    "authors": [
        {
            "name": "Koen Schipper",
            "email": "info@koenschipper.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "KoenSchipper\\AddressParser\\": "src/",
            "KoenSchipper\\AddressParser\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KoenSchipper\\AddressParser\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KoenSchipper\\AddressParser\\LaravelAddressParserServiceProvider"
            ],
            "aliases": {
                "LaravelAddressParser": "KoenSchipper\\AddressParser\\Facades\\LaravelAddressParser"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
